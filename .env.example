# ===== 服务配置 =====
PORT=3000
NODE_ENV=production

# ===== SQLite 数据库 =====
SQLITE_DB_PATH=./data/payment.db

# ===== Redis 配置 =====
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== 加密密钥 =====
AES_SECRET_KEY=your-aes-256-secret-key-here-32ch
AES_IV=your-aes-iv-16char

# ===== JWT 配置（管理后台） =====
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=24h

# ===== TRC20 RPC 配置 =====
TRON_FULL_HOST=https://api.trongrid.io
TRON_API_KEY=ac02424f-ef2c-4ae1-a92b-3619b9996aaa
TRON_BACKUP_HOST=https://api.shasta.trongrid.io

# ===== BSC RPC 配置 =====
BSC_RPC_URL=https://bsc-dataseed1.binance.org
BSC_BACKUP_RPC_URL=https://bsc-dataseed2.binance.org
BSC_CHAIN_ID=56

# ===== USDT 合约地址 =====
TRC20_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
BSC_USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955

# ===== 充币扫描配置 =====
DEPOSIT_SCAN_INTERVAL=30000
TRC20_CONFIRM_BLOCKS=20
BSC_CONFIRM_BLOCKS=15

# ===== 归集配置 =====
COLLECTION_THRESHOLD=10
COLLECTION_MAIN_ADDRESS_TRC20=
COLLECTION_MAIN_ADDRESS_BSC=
COLLECTION_CRON=0 */6 * * *

# ===== 风控配置 =====
WITHDRAW_MAX_AMOUNT=50000
WITHDRAW_DAILY_LIMIT=200000

# ===== 回调配置 =====
CALLBACK_MAX_RETRY=5
CALLBACK_RETRY_INTERVAL=60000

# ===== 管理员默认账号 =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
